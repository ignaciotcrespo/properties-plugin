<idea-plugin>
  <id>ignaciotcrespo.github.com.android-gradle-switches</id>
  <name>Properties</name>
  <vendor email="itcrespo@gmail.com" url="https://github.com/ignaciotcrespo">Ignacio Tomas Crespo</vendor>

  <description><![CDATA[
    <p>Display all properties in the entire project, searching in ".properties" files.</p>
    ]]></description>

  <change-notes><![CDATA[
      - Migrated to Gradle build system<br>
      - Updated to modern IntelliJ Platform APIs<br>
    ]]>
  </change-notes>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <toolWindow id="Properties!" icon="/ic_props13x13.png" anchor="right"
                factoryClass="com.github.ignaciotcrespo.ags.GradleSwitchesToolWindowFactory"/>
  </extensions>

</idea-plugin>
