<idea-plugin>
  <id>ignaciotcrespo.github.com.android-gradle-switches</id>
  <name>Properties</name>
  <version>1.1.0</version>
  <vendor email="itcrespo@gmail.com" url="https://github.com/ignaciotcrespo">Ignacio Tomas Crespo</vendor>

  <description><![CDATA[
    <p>Display all properties in the entire project, searching in ".properties" files and "settings.gradle" file.</p>
    <p>Show also a quick reference of properties useful for android builds</p>
    ]]></description>

  <change-notes><![CDATA[
      - Bugfixes <br>
      - Updated info added in quick reference for android.
    ]]>
  </change-notes>

  <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/build_number_ranges.html for description -->
  <idea-version since-build="173.0"/>

  <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/plugin_compatibility.html
       on how to target different products -->
  <!-- uncomment to enable plugin in all products
  <depends>com.intellij.modules.lang</depends>
  -->

  <extensions defaultExtensionNs="com.intellij">
    <!-- Add your extensions here -->
    <!-- icons specs: https://www.jetbrains.org/intellij/sdk/docs/reference_guide/work_with_icons_and_images.html -->
    <toolWindow id="Properties!" icon="/ic_props13x13.png" anchor="right" factoryClass="com.github.ignaciotcrespo.ags.GradleSwitchesToolWindowFactory"/>
  </extensions>

  <actions>
    <!-- Add your actions here -->
  </actions>

</idea-plugin>